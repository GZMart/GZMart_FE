# API Configuration - Backend chạy trên port 3000
VITE_API_BASE_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000

# AI Services (optional - chưa cần thiết cho homepage)
VITE_GOOGLE_VISION_API_KEY=your_google_vision_api_key
VITE_OPENAI_API_KEY=sk-proj-abcdefghijklmnopqrstuvwxyz123456789
VITE_GEMINI_API_KEY=AIzaSyABCDEFGHIJKLMNOPQRSTUVWXYZ12345

# Application
VITE_APP_NAME=GZMart
VITE_APP_ENV=development

# OAuth Configuration
VITE_GOOGLE_CLIENT_ID=123456789012-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
VITE_FACEBOOK_APP_ID=1234567890123456

# Goong Map (Order Tracking)
# Preferred (Vite standard)
VITE_GOONG_MAPTILES_KEY=your_goong_maptiles_key
VITE_GOONG_API_KEY=your_goong_api_key
# Backward compatible names (also supported)
GOONG_MAPTILES_KEY=your_goong_maptiles_key
GOONG_API_KEY=your_goong_api_key

# Optional: custom icon for delivery vehicle marker on tracking map
# Example: /icons/delivery-bike.png (file inside public/icons)
VITE_DELIVERY_VEHICLE_ICON_URL=
DELIVERY_VEHICLE_ICON_URL=

# Optional: custom icon for seller and buyer markers on tracking map
# Example: /icons/store-marker.png and /icons/home-marker.png
VITE_DELIVERY_SELLER_ICON_URL=
DELIVERY_SELLER_ICON_URL=
VITE_DELIVERY_BUYER_ICON_URL=
DELIVERY_BUYER_ICON_URL=